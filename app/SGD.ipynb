   "source": [
    "import numpy as np\n",
    "\n",
    "class SGD:\n",
    "    def __init__(self, learning_rate=0.01):\n",
    "        self.learning_rate = learning_rate\n",
    "\n",
    "    def update(self, params, grads):\n",
    "        for param, grad in zip(params, grads):\n",
    "            param -= self.learning_rate * grad"
   ]
